// =============================================================
// Celator — Prisma Schema (Phase 0: Security Foundation)
// =============================================================
// This schema covers the full data model for Phase 0.
// No browser automation, LLM agents, or real submission tables yet.
// =============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// ENUMS
// =============================================================

enum ClientStatus {
  PENDING_IDENTITY_VERIFICATION
  ACTIVE
  SUSPENDED
  DISPUTED
  CLOSED
}

enum AuthorizationType {
  SELF
  LEGAL_GUARDIAN
  POWER_OF_ATTORNEY
  EMPLOYER_SAFETY
  DECEASED_ESTATE
  ATTORNEY_CLIENT
}

enum TaskStatus {
  FOUND
  CLASSIFIED
  MATCH_REVIEW_REQUIRED
  CLIENT_CONFIRMATION_REQUIRED
  READY_FOR_OPERATOR_REVIEW
  OPERATOR_APPROVED
  OPERATOR_REJECTED
  READY_TO_SUBMIT
  SUBMITTED
  DELIVERED
  BROKER_CONFIRMED_RECEIPT
  BROKER_REJECTED
  MORE_INFO_REQUESTED
  WAITING_VERIFICATION
  VERIFIED_REMOVED
  PARTIALLY_REMOVED
  FAILED
  REAPPEARED
  MANUAL_ONLY
  ESCALATED
  FALSE_POSITIVE
  SKIPPED
  NEEDS_OPERATOR_REVIEW
  BLOCKED_CONSENT_SCOPE
  PAUSED_BY_SYSTEM
}

enum MatchStatus {
  CONFIRMED_MATCH
  CLIENT_CONFIRMED
  LIKELY_MATCH
  POSSIBLE_MATCH
  NEEDS_CLIENT_REVIEW
  NEEDS_OPERATOR_REVIEW
  FALSE_POSITIVE
}

enum SnapshotStatus {
  ACTIVE
  EXPIRED
  USED
  INVALIDATED
}

enum RiskTier {
  STANDARD
  MEDIUM
  HIGH
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum OperatorDecision {
  APPROVED
  REJECTED
  ESCALATED
  NEEDS_MORE_EVIDENCE
}

enum EmergencyPauseScope {
  GLOBAL
  CLIENT
  BROKER
  OPERATOR
  JURISDICTION
}

enum EmergencyPauseStatus {
  ACTIVE
  RESOLVED
}

enum ActorType {
  SYSTEM
  CLIENT
  OPERATOR
  ADMIN
  SERVICE
}

enum VaultPurposeCode {
  PURPOSE_OPERATOR_REVIEW_PACKET
  PURPOSE_FORM_FILL
  PURPOSE_REPORT_GENERATION
  PURPOSE_CLIENT_EXPORT
  PURPOSE_DEK_ROTATION
}

enum HighRiskFlagType {
  MINOR_DATA
  DOMESTIC_VIOLENCE_SAFETY
  PUBLIC_FIGURE
  MEDICAL_DATA
  FINANCIAL_DATA
  LEGAL_DATA
  COURT_RECORD
  PROPERTY_RECORD
  UNCERTAIN_MATCH
  ID_DOCUMENT_REQUIRED
  LEGAL_ESCALATION
}

enum WarningType {
  MATCH_CONFIDENCE_LOW
  PLAYBOOK_NOT_RECENTLY_TESTED
  PREVIOUSLY_REJECTED_BY_BROKER
  SENSITIVE_DATA_REQUIRED
  SAME_OPERATOR_PREPARED
  HIGH_RISK_FLAG_PRESENT
  RESUBMISSION
  SNAPSHOT_APPROACHING_EXPIRY
  SEGREGATION_OF_DUTIES_REQUIRED
  PLAYBOOK_EXCEPTION_ACTIVE
  BROKER_ON_LEGAL_HOLD
}

enum DekRotationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum ActionType {
  OPT_OUT
  DELETE_PERSONAL_DATA
  DO_NOT_SELL
  DO_NOT_SHARE
  LIMIT_SENSITIVE_DATA
  CORRECT_DATA
  REMOVE_FROM_SEARCH
  REFRESH_OUTDATED_CONTENT
  DELETE_ACCOUNT
  DEACTIVATE_ACCOUNT
  REMOVE_IMAGE
  SUPPRESS_PROFILE
  REPORT_DANGEROUS_EXPOSURE
  ESCALATE_NON_RESPONSE
  LEGAL_ESCALATION
}

enum IdentityVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  REQUIRES_DOCUMENT_REVIEW
}

// =============================================================
// ORGANIZATIONS & USERS
// =============================================================

model Organization {
  id          String   @id @default(cuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive    Boolean  @default(true)

  users          User[]
  clients        Client[]
  intakeSessions ClientIntakeSession[]

  @@map("organizations")
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String   @unique
  // No password storage — auth via external provider
  displayName    String
  isActive       Boolean  @default(true)
  mfaEnabled     Boolean  @default(false)
  lastMfaAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id])
  userRoles      UserRole[]
  operatorApprovals OperatorApproval[]
  auditLogs      AuditLog[]     @relation("AuditActor")
  qualityMetrics OperatorQualityMetric[]
  pauseEvents    EmergencyPauseEvent[]
  warnAcks       OperatorWarningAcknowledgment[]

  @@index([organizationId])
  @@index([isActive])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  userRoles   UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  grantedAt DateTime @default(now())
  grantedBy String?

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@map("user_roles")
}

// =============================================================
// CLIENTS & CONSENT
// =============================================================

model Client {
  id             String       @id @default(cuid())
  organizationId String
  status         ClientStatus @default(PENDING_IDENTITY_VERIFICATION)
  displayName    String
  // No PII stored here — PII lives in IdentityVaultRecord
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  hasDisputeFlag Boolean      @default(false)
  hasComplianceHold Boolean   @default(false)

  organization         Organization               @relation(fields: [organizationId], references: [id])
  identityVerifications ClientIdentityVerification[]
  authorizations        ClientAuthorization[]
  vaultRecords          IdentityVaultRecord[]
  cleanupCases          CleanupCase[]
  highRiskFlags         HighRiskFlag[]
  auditLogs             AuditLog[]                 @relation("AuditClient")
  portalEvents          ClientPortalEvent[]
  dataDeletionRequests  ClientDataDeletionRequest[]
  dekRotationJobs       DekRotationJob[]
  manualSubmissions        ManualRemovalSubmission[]
  workflowRuns             TaskWorkflowRun[]
  evidenceRecords          EvidenceRecord[]
  removalRequestPackets    RemovalRequestPacket[]
  followUpReminders        FollowUpReminder[]
  intakeSessions           ClientIntakeSession[]
  scheduledNotifications   ScheduledNotification[]
  caseReports              CaseReport[]
  automationPlans          AutomationPlan[]

  @@index([organizationId])
  @@index([status])
  @@map("clients")
}

model ClientIdentityVerification {
  id          String                    @id @default(cuid())
  clientId    String
  status      IdentityVerificationStatus @default(PENDING)
  // Operator attestation text (not the document itself)
  operatorAttestation String?
  operatorId  String?
  verifiedAt  DateTime?
  rejectedAt  DateTime?
  rejectionReason String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([status])
  @@map("client_identity_verifications")
}

model ClientAuthorization {
  id               String            @id @default(cuid())
  clientId         String
  authorizationType AuthorizationType @default(SELF)
  scopeNames       String[]          // e.g. ["DATA_BROKER_OPT_OUT", "SEARCH_RESULT_REMOVAL"]
  jurisdiction     String            // e.g. "US-CA", "US", "UK"
  signedAt         DateTime
  expiresAt        DateTime?
  revokedAt        DateTime?
  revocationReason String?
  consentVersionId String
  createdAt        DateTime          @default(now())

  client         Client          @relation(fields: [clientId], references: [id])
  consentVersion ConsentVersion  @relation(fields: [consentVersionId], references: [id])
  approvalRequests ApprovalRequest[]
  cleanupCases   CleanupCase[]

  @@index([clientId])
  @@index([revokedAt])
  @@index([expiresAt])
  @@map("client_authorizations")
}

model ConsentVersion {
  id          String   @id @default(cuid())
  version     String   // semver e.g. "1.0.0"
  documentHash String  // SHA-256 of the consent document text
  effectiveFrom DateTime
  effectiveUntil DateTime?
  createdAt   DateTime @default(now())

  authorizations ClientAuthorization[]

  @@unique([version])
  @@index([effectiveFrom])
  @@map("consent_versions")
}

// Append-only. Never update or delete rows. See ConsentPolicyService.
model ConsentScopeMapping {
  id             String    @id @default(cuid())
  scopeName      String
  actionType     ActionType
  jurisdiction   String    // e.g. "US-CA", "US", "*" for all
  permitted      Boolean
  requiredLanguageNote String?
  effectiveFrom  DateTime
  effectiveUntil DateTime?
  createdBy      String    // userId of admin who created
  createdAt      DateTime  @default(now())
  // NO updatedAt — this record must never be modified

  @@index([scopeName, actionType, jurisdiction, effectiveFrom])
  @@map("consent_scope_mappings")
}

// =============================================================
// IDENTITY VAULT
// =============================================================

model IdentityVaultRecord {
  id               String   @id @default(cuid())
  clientId         String
  fieldType        String   // e.g. "EMAIL", "PHONE", "ADDRESS", "DOB", "USERNAME"
  ciphertext       String   // Base64-encoded AES-256-GCM ciphertext
  iv               String   // Base64-encoded IV
  authTag          String   // Base64-encoded GCM auth tag
  keyId            String   // KMS DEK key identifier (not the key itself)
  keyVersion       String
  encryptedKeyRef  String?  @map("encrypted_key_ref") // Wrapped DEK ref (for dev LocalKMS); null in production KMS
  redactedDisplay  String?  @map("redacted_display")  // Pre-computed safe display, e.g. "j***@example.com"
  isCryptoShredded Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  client     Client              @relation(fields: [clientId], references: [id])
  accessLogs IdentityVaultAccessLog[]
  evidenceHolds SnapshotEvidenceHold[] @relation("EvidenceHoldVault")

  @@index([clientId])
  @@index([clientId, fieldType])
  @@map("identity_vault_records")
}

model IdentityVaultAccessLog {
  id          String           @id @default(cuid())
  recordId    String
  clientId    String
  purposeCode VaultPurposeCode
  actorId     String
  actorType   ActorType
  accessedAt  DateTime         @default(now())
  // No plaintext, no values — IDs and purposes only

  record IdentityVaultRecord @relation(fields: [recordId], references: [id])

  @@index([recordId])
  @@index([clientId, accessedAt])
  @@map("identity_vault_access_logs")
}

model DekRotationJob {
  id              String          @id @default(cuid())
  clientId        String
  oldKeyVersion   String
  newKeyVersion   String
  status          DekRotationStatus @default(PENDING)
  recordsTotal    Int             @default(0)
  recordsRotated  Int             @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  failureReason   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId, status])
  @@map("dek_rotation_jobs")
}

// =============================================================
// CLEANUP CASES & TASKS
// =============================================================

model CleanupCase {
  id              String   @id @default(cuid())
  clientId        String
  authorizationId String
  title           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  closedAt        DateTime?

  client        Client               @relation(fields: [clientId], references: [id])
  authorization ClientAuthorization  @relation(fields: [authorizationId], references: [id])
  tasks         CleanupTask[]
  timelineEvents CaseTimelineEvent[]
  scheduledNotifications ScheduledNotification[]
  caseReports   CaseReport[]

  @@index([clientId])
  @@map("cleanup_cases")
}

model CleanupTask {
  id                   String      @id @default(cuid())
  caseId               String
  dataSourceTargetId   String?
  status               TaskStatus  @default(FOUND)
  actionType           ActionType?
  matchStatus          MatchStatus @default(NEEDS_OPERATOR_REVIEW)
  riskTier             RiskTier    @default(STANDARD)
  sourceRef            String?     // broker/source name
  findingUrl           String?
  preparedByUserId     String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  case             CleanupCase           @relation(fields: [caseId], references: [id])
  dataSourceTarget DataSourceTarget?     @relation(fields: [dataSourceTargetId], references: [id])
  approvalRequests ApprovalRequest[]
  highRiskFlags    HighRiskFlag[]
  evidenceRecords  EvidenceRecord[]
  timelineEvents   CaseTimelineEvent[]   @relation("TaskTimeline")
  manualSubmissions ManualRemovalSubmission[]
  workflowRuns     TaskWorkflowRun[]
  removalRequestPackets RemovalRequestPacket[]
  followUpReminders     FollowUpReminder[]
  scheduledNotifications ScheduledNotification[]
  automationPlans        AutomationPlan[]

  @@index([caseId, status])
  @@index([status])
  @@index([riskTier, status])
  @@index([dataSourceTargetId])
  @@map("cleanup_tasks")
}

model AllowedStatusTransition {
  id         String     @id @default(cuid())
  fromStatus TaskStatus
  toStatus   TaskStatus
  createdAt  DateTime   @default(now())

  @@unique([fromStatus, toStatus])
  @@map("allowed_status_transitions")
}

// =============================================================
// APPROVAL SYSTEM
// =============================================================

model ApprovalPayloadSnapshot {
  id               String         @id @default(cuid())
  taskId           String
  payloadHash      String         // SHA-256 of canonical JSON payload
  snapshotSignature String        // HMAC-SHA256 of payloadHash
  signingKeyVersion String
  snapshotStatus   SnapshotStatus @default(ACTIVE)
  snapshotExpiresAt DateTime
  riskTier         RiskTier
  actionType       ActionType
  redactedPreview  String         // Human-readable, PII-redacted summary
  invalidationReason String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  approvalRequests ApprovalRequest[]
  operatorApprovals OperatorApproval[]
  evidenceHolds    SnapshotEvidenceHold[]

  @@index([taskId])
  @@index([snapshotStatus, snapshotExpiresAt])
  @@map("approval_payload_snapshots")
}

model SnapshotEvidenceHold {
  id          String    @id @default(cuid())
  snapshotId  String
  evidenceId  String?   // EvidenceRecord id if applicable
  vaultRecordId String? // IdentityVaultRecord id if applicable
  heldUntil   DateTime
  releasedAt  DateTime?
  createdAt   DateTime  @default(now())

  snapshot  ApprovalPayloadSnapshot @relation(fields: [snapshotId], references: [id])
  evidence  EvidenceRecord?         @relation(fields: [evidenceId], references: [id])
  vaultRecord IdentityVaultRecord?  @relation("EvidenceHoldVault", fields: [vaultRecordId], references: [id])

  @@index([snapshotId])
  @@index([evidenceId])
  @@map("snapshot_evidence_holds")
}

model ApprovalRequest {
  id              String                @id @default(cuid())
  taskId          String
  authorizationId String
  snapshotId      String
  status          ApprovalRequestStatus @default(PENDING)
  preparedByUserId String?
  expiresAt       DateTime
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  task          CleanupTask             @relation(fields: [taskId], references: [id])
  authorization ClientAuthorization     @relation(fields: [authorizationId], references: [id])
  snapshot      ApprovalPayloadSnapshot @relation(fields: [snapshotId], references: [id])
  operatorApproval OperatorApproval?
  warningAcknowledgments OperatorWarningAcknowledgment[]

  @@index([taskId, status])
  @@index([status, expiresAt])
  @@map("approval_requests")
}

model OperatorApproval {
  id                String           @id @default(cuid())
  approvalRequestId String           @unique
  snapshotId        String
  operatorId        String
  decision          OperatorDecision
  mfaFreshAt        DateTime         // timestamp of last MFA before approval
  sessionApprovalCount Int           @default(0)
  reviewStartedAt   DateTime?
  approvedAt        DateTime         @default(now())
  notes             String?

  approvalRequest ApprovalRequest         @relation(fields: [approvalRequestId], references: [id])
  snapshot        ApprovalPayloadSnapshot @relation(fields: [snapshotId], references: [id])
  operator        User                    @relation(fields: [operatorId], references: [id])

  @@index([operatorId, approvedAt])
  @@index([snapshotId])
  @@map("operator_approvals")
}

model OperatorWarningAcknowledgment {
  id                String      @id @default(cuid())
  approvalRequestId String
  warningType       WarningType
  operatorId        String
  acknowledgedAt    DateTime    @default(now())

  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id])
  operator        User            @relation(fields: [operatorId], references: [id])

  @@unique([approvalRequestId, warningType])
  @@map("operator_warning_acknowledgments")
}

model OperatorQualityMetric {
  id                        String   @id @default(cuid())
  operatorId                String
  sessionId                 String
  approvalsInSession        Int      @default(0)
  rejectionsInSession       Int      @default(0)
  avgReviewTimeSecondsSession Float  @default(0)
  bulkApprovalAttempted     Boolean  @default(false)
  selfApprovalFlagged       Boolean  @default(false)
  highRiskApprovalsInSession Int     @default(0)
  sessionStartedAt          DateTime
  sessionEndedAt            DateTime?
  createdAt                 DateTime @default(now())

  operator User @relation(fields: [operatorId], references: [id])

  @@index([operatorId, createdAt])
  @@map("operator_quality_metrics")
}

// =============================================================
// EMERGENCY PAUSE
// =============================================================

model EmergencyPauseEvent {
  id             String               @id @default(cuid())
  scope          EmergencyPauseScope
  scopeRef       String?              // clientId, operatorId, brokerId, or jurisdiction string
  status         EmergencyPauseStatus @default(ACTIVE)
  reason         String
  triggeredBy    String               // userId
  triggeredAt    DateTime             @default(now())
  resolvedBy     String?
  resolvedAt     DateTime?
  resolutionSummary String?
  // For GLOBAL pause: requires 2-admin consensus (Phase 0 scaffolds this)
  requiresDualAdmin Boolean           @default(false)
  secondAdminApprovedBy String?
  secondAdminApprovedAt DateTime?

  triggerer User  @relation(fields: [triggeredBy], references: [id])
  // scopeRef is polymorphic: holds a clientId, operatorId, broker ref, or jurisdiction string
  // depending on scope. No FK constraint — polymorphic fields cannot reference a single table.

  @@index([status, scope])
  @@index([scopeRef, status])
  @@map("emergency_pause_events")
}

// =============================================================
// AUDIT LOG
// =============================================================

model AuditLog {
  id          String    @id @default(cuid())
  eventType   String    // e.g. "APPROVAL_GATE_BLOCKED", "SNAPSHOT_CREATED", "CONSENT_REVOKED"
  actorId     String?
  actorType   ActorType
  clientId    String?
  resourceId  String?   // ID of the affected resource
  resourceType String?  // e.g. "CleanupTask", "ApprovalRequest"
  outcome     String    // "ALLOWED", "BLOCKED", "ERROR"
  blockedBy   String[]  // Which checks blocked, if any
  metadata    Json?     // Safe metadata — NO PII
  createdAt   DateTime  @default(now())

  actor  User?   @relation("AuditActor", fields: [actorId], references: [id])
  client Client? @relation("AuditClient", fields: [clientId], references: [id])

  @@index([clientId, createdAt])
  @@index([actorId, createdAt])
  @@index([eventType, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================
// CASE TIMELINE
// =============================================================

model CaseTimelineEvent {
  id           String    @id @default(cuid())
  caseId       String
  taskId       String?
  eventType    String
  fromStatus   TaskStatus?
  toStatus     TaskStatus?
  actorId      String?
  actorType    ActorType
  note         String?
  createdAt    DateTime  @default(now())

  case CleanupCase  @relation(fields: [caseId], references: [id])
  task CleanupTask? @relation("TaskTimeline", fields: [taskId], references: [id])

  @@index([caseId, createdAt])
  @@index([taskId, createdAt])
  @@map("case_timeline_events")
}

// =============================================================
// EVIDENCE
// =============================================================

model EvidenceRecord {
  id              String   @id @default(cuid())
  taskId          String
  clientId        String?  // Phase 2C: direct client scope for ownership checks
  storageKey      String   // Object storage path — not the content
  contentHash     String   // SHA-256 of stored content; server-computed, not caller-supplied
  evidenceType    String   // validated at service layer: SCREENSHOT, CONFIRMATION_CODE, EMAIL_RESPONSE, WEB_FORM_RECEIPT, MANUAL_NOTE, OTHER
  mimeType        String?
  sizeBytes       Int?
  isImmutable     Boolean  @default(false)
  retainUntil     DateTime?
  createdAt       DateTime @default(now())

  task             CleanupTask            @relation(fields: [taskId], references: [id])
  client           Client?                @relation(fields: [clientId], references: [id])
  evidenceHolds    SnapshotEvidenceHold[]
  workflowStepRuns TaskWorkflowStepRun[]

  @@index([taskId])
  @@index([clientId])
  @@map("evidence_records")
}

// =============================================================
// HIGH RISK FLAGS
// =============================================================

model HighRiskFlag {
  id         String          @id @default(cuid())
  clientId   String
  taskId     String?
  flagType   HighRiskFlagType
  flaggedBy  String          // userId
  flaggedAt  DateTime        @default(now())
  resolvedAt DateTime?
  resolvedBy String?
  notes      String?

  client Client      @relation(fields: [clientId], references: [id])
  task   CleanupTask? @relation(fields: [taskId], references: [id])

  @@index([clientId, resolvedAt])
  @@index([taskId])
  @@map("high_risk_flags")
}

// =============================================================
// LEGAL HOLD SOURCES
// =============================================================

model LegalHoldSource {
  id          String   @id @default(cuid())
  sourceRef   String   @unique // broker name, domain, or identifier
  reason      String
  heldBy      String   // userId
  heldAt      DateTime @default(now())
  releasedAt  DateTime?
  releasedBy  String?

  @@index([releasedAt])
  @@map("legal_hold_sources")
}

// =============================================================
// CLIENT PORTAL EVENTS
// =============================================================

model ClientPortalEvent {
  id         String   @id @default(cuid())
  clientId   String
  eventType  String   // "LOGIN", "CONSENT_SIGNED", "MATCH_CONFIRMED", "CONSENT_REVOKED"
  ipHash     String?  // Hashed IP — not raw IP
  metadata   Json?    // Safe metadata only
  createdAt  DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId, createdAt])
  @@map("client_portal_events")
}

// =============================================================
// CLIENT DATA DELETION REQUESTS
// =============================================================

model ClientDataDeletionRequest {
  id                String    @id @default(cuid())
  clientId          String
  requestedAt       DateTime  @default(now())
  requestedBy       String    // userId or "CLIENT_SELF"
  completedAt       DateTime?
  retainedRecords   Json?     // What was kept and why (legal hold, audit retention)
  cryptoShredded    Boolean   @default(false)
  cryptoShredAt     DateTime?
  notes             String?

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@map("client_data_deletion_requests")
}

// =============================================================
// DATA SOURCE TARGETS (Phase 1D)
// =============================================================
// Foundation model for future deletion/opt-out workflows.
// Describes where data may be found and what is needed to remove it.
// Does NOT execute removal — that is a future phase.

enum SourceType {
  DATA_BROKER
  SEARCH_ENGINE
  SOCIAL_PLATFORM
  PUBLIC_RECORD_SITE
  PEOPLE_SEARCH
  BREACH_INDEX
  OTHER
}

// =============================================================
// WORKFLOW ENGINE + PLAYBOOKS (Phase 2A)
// =============================================================

enum PlaybookStatus {
  ACTIVE
  INACTIVE
  DEPRECATED
}

enum WorkflowRunStatus {
  IN_PROGRESS
  WAITING
  BLOCKED
  COMPLETED
  FAILED
  CANCELLED
}

enum WorkflowStepStatus {
  PENDING
  READY
  IN_PROGRESS
  WAITING
  COMPLETED
  BLOCKED
  SKIPPED
  FAILED
}

enum WorkflowStepKind {
  VERIFY_TARGET_REQUIREMENTS
  PREPARE_REMOVAL_DRAFT
  OPERATOR_REVIEW
  MANUAL_SUBMISSION
  WAIT_FOR_CONFIRMATION
  RECORD_OUTCOME
  VERIFY_REMOVAL
  CLOSE_TASK
  CUSTOM
}

model RemovalPlaybook {
  id                 String         @id @default(cuid())
  name               String
  version            String
  sourceType         SourceType?    @map("source_type")
  dataSourceTargetId String?        @map("data_source_target_id")
  status             PlaybookStatus @default(ACTIVE)
  description        String?
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt       @map("updated_at")

  dataSourceTarget DataSourceTarget?       @relation(fields: [dataSourceTargetId], references: [id])
  steps            RemovalPlaybookStep[]
  workflowRuns     TaskWorkflowRun[]

  @@unique([name, version])
  @@index([status])
  @@index([dataSourceTargetId, status])
  @@index([sourceType, status])
  @@map("removal_playbooks")
}

model RemovalPlaybookStep {
  id                       String           @id @default(cuid())
  playbookId               String           @map("playbook_id")
  stepOrder                Int              @map("step_order")
  stepKind                 WorkflowStepKind @map("step_kind")
  title                    String
  instructions             String
  requiresApproval         Boolean          @default(false) @map("requires_approval")
  requiresManualSubmission Boolean          @default(false) @map("requires_manual_submission")
  requiredEvidenceType     String?          @map("required_evidence_type")
  createdAt                DateTime         @default(now()) @map("created_at")
  updatedAt                DateTime         @updatedAt       @map("updated_at")

  playbook RemovalPlaybook        @relation(fields: [playbookId], references: [id])
  stepRuns TaskWorkflowStepRun[]

  @@unique([playbookId, stepOrder])
  @@index([playbookId])
  @@map("removal_playbook_steps")
}

model TaskWorkflowRun {
  id               String            @id @default(cuid())
  taskId           String            @map("task_id")
  clientId         String            @map("client_id")
  playbookId       String            @map("playbook_id")
  status           WorkflowRunStatus @default(IN_PROGRESS)
  currentStepOrder Int?              @map("current_step_order")
  startedAt        DateTime?         @map("started_at")
  completedAt      DateTime?         @map("completed_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt       @map("updated_at")

  task     CleanupTask           @relation(fields: [taskId], references: [id])
  client   Client                @relation(fields: [clientId], references: [id])
  playbook RemovalPlaybook       @relation(fields: [playbookId], references: [id])
  stepRuns TaskWorkflowStepRun[]

  @@index([taskId])
  @@index([clientId, createdAt])
  @@index([status])
  @@map("task_workflow_runs")
}

model TaskWorkflowStepRun {
  id                 String             @id @default(cuid())
  workflowRunId      String             @map("workflow_run_id")
  playbookStepId     String             @map("playbook_step_id")
  stepOrder          Int                @map("step_order")
  stepKind           WorkflowStepKind   @map("step_kind")
  status             WorkflowStepStatus @default(PENDING)
  operatorNotes      String?            @map("operator_notes")
  safeResultSummary  String?            @map("safe_result_summary")
  evidenceRecordId   String?            @map("evidence_record_id")
  manualSubmissionId String?            @map("manual_submission_id")
  startedAt          DateTime?          @map("started_at")
  completedAt        DateTime?          @map("completed_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt       @map("updated_at")

  workflowRun      TaskWorkflowRun         @relation(fields: [workflowRunId], references: [id])
  playbookStep     RemovalPlaybookStep     @relation(fields: [playbookStepId], references: [id])
  evidenceRecord   EvidenceRecord?         @relation(fields: [evidenceRecordId], references: [id])
  manualSubmission ManualRemovalSubmission? @relation(fields: [manualSubmissionId], references: [id])

  @@index([workflowRunId])
  @@index([workflowRunId, stepOrder])
  @@map("task_workflow_step_runs")
}

// =============================================================
// MANUAL REMOVAL SUBMISSIONS (Phase 1F)
// =============================================================

enum SubmissionMethod {
  WEB_FORM
  EMAIL
  SUPPORT_PORTAL
  PHONE
  MAIL
  OTHER
}

enum SubmissionStatus {
  DRAFTED
  READY_FOR_MANUAL_SUBMISSION
  SUBMITTED
  ACKNOWLEDGED
  REJECTED
  NEEDS_MORE_INFO
  COMPLETED
  FAILED
}

model ManualRemovalSubmission {
  id                  String           @id @default(cuid())
  taskId              String           @map("task_id")
  dataSourceTargetId  String           @map("data_source_target_id")
  clientId            String           @map("client_id")
  submittedByUserId   String?          @map("submitted_by_user_id")
  submissionMethod    SubmissionMethod @map("submission_method")
  submissionStatus    SubmissionStatus @default(DRAFTED) @map("submission_status")
  submittedAt         DateTime?        @map("submitted_at")
  confirmationCode    String?          @map("confirmation_code")
  confirmationUrl     String?          @map("confirmation_url")
  operatorNotes       String?          @map("operator_notes")
  redactedSummary     String           @map("redacted_summary")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt      @map("updated_at")

  task             CleanupTask      @relation(fields: [taskId], references: [id])
  dataSourceTarget DataSourceTarget @relation(fields: [dataSourceTargetId], references: [id])
  client           Client           @relation(fields: [clientId], references: [id])
  workflowStepRuns TaskWorkflowStepRun[]

  @@index([taskId])
  @@index([clientId, createdAt])
  @@index([submissionStatus])
  @@map("manual_removal_submissions")
}

// =============================================================
// DATA SOURCE TARGETS (Phase 1E)
// =============================================================

model DataSourceTarget {
  id                   String       @id @default(cuid())
  sourceName           String       @unique  @map("source_name")
  sourceType           SourceType             @map("source_type")
  baseDomain           String?                @map("base_domain")
  jurisdiction         String?
  supportedActionTypes ActionType[]           @map("supported_action_types")
  requiresLogin        Boolean      @default(false) @map("requires_login")
  requiresCaptcha      Boolean      @default(false) @map("requires_captcha")
  manualOnly           Boolean      @default(false) @map("manual_only")
  piiRequiredFields    String[]               @map("pii_required_fields")
  notes                String?
  isActive             Boolean      @default(true)  @map("is_active")
  createdAt            DateTime     @default(now())  @map("created_at")
  updatedAt            DateTime     @updatedAt       @map("updated_at")

  cleanupTasks             CleanupTask[]
  manualRemovalSubmissions ManualRemovalSubmission[]
  playbooks                RemovalPlaybook[]
  removalRequestPackets    RemovalRequestPacket[]

  @@index([sourceType, isActive])
  @@map("data_source_targets")
}

// =============================================================
// REMOVAL REQUEST PACKETS (Phase 2B)
// =============================================================

enum PacketStatus {
  DRAFT
  READY
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PacketItemStatus {
  PENDING
  COMPLETED
  BLOCKED
  SKIPPED
}

model RemovalRequestPacket {
  id                 String       @id @default(cuid())
  taskId             String       @map("task_id")
  clientId           String       @map("client_id")
  dataSourceTargetId String?      @map("data_source_target_id")
  status             PacketStatus @default(DRAFT)
  redactedSummary    String       @map("redacted_summary")
  preparedByUserId   String?      @map("prepared_by_user_id")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt       @map("updated_at")

  task             CleanupTask               @relation(fields: [taskId], references: [id])
  client           Client                    @relation(fields: [clientId], references: [id])
  dataSourceTarget DataSourceTarget?         @relation(fields: [dataSourceTargetId], references: [id])
  items            RemovalRequestPacketItem[]

  @@index([taskId])
  @@index([clientId, createdAt])
  @@index([status])
  @@map("removal_request_packets")
}

model RemovalRequestPacketItem {
  id                String           @id @default(cuid())
  packetId          String           @map("packet_id")
  itemOrder         Int              @map("item_order")
  itemKind          String           @map("item_kind")
  label             String
  status            PacketItemStatus @default(PENDING)
  requiredFieldType String?          @map("required_field_type")
  operatorNotes     String?          @map("operator_notes")
  completedAt       DateTime?        @map("completed_at")
  createdAt         DateTime         @default(now()) @map("created_at")

  packet RemovalRequestPacket @relation(fields: [packetId], references: [id])

  @@unique([packetId, itemOrder])
  @@index([packetId])
  @@map("removal_request_packet_items")
}

// =============================================================
// FOLLOW-UP REMINDERS (Phase 2C)
// =============================================================

enum FollowUpStatus {
  PENDING
  DUE
  COMPLETED
  CANCELLED
}

// =============================================================
// CLIENT INTAKE (Phase 3B)
// =============================================================

enum ClientIntakeStatus {
  STARTED
  CONTACT_CAPTURED
  CONSENT_PENDING
  IDENTITY_PENDING
  READY_FOR_REVIEW
  COMPLETED
  CANCELLED
  EXPIRED
}

model FollowUpReminder {
  id                String         @id @default(cuid())
  taskId            String         @map("task_id")
  clientId          String         @map("client_id")
  status            FollowUpStatus @default(PENDING)
  dueAt             DateTime       @map("due_at")
  safeNote          String?        @map("safe_note")
  completedAt       DateTime?      @map("completed_at")
  cancelledAt       DateTime?      @map("cancelled_at")
  createdByUserId   String?        @map("created_by_user_id")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt       @map("updated_at")

  task   CleanupTask @relation(fields: [taskId], references: [id])
  client Client      @relation(fields: [clientId], references: [id])
  scheduledNotifications ScheduledNotification[]

  @@index([taskId])
  @@index([clientId, dueAt])
  @@index([status, dueAt])
  @@map("follow_up_reminders")
}

model ClientIntakeSession {
  id                   String              @id @default(cuid())
  clientId             String?             @map("client_id")
  orgId                String              @map("org_id")
  status               ClientIntakeStatus  @default(STARTED)
  safeContactRef       String?             @map("safe_contact_ref")
  requestedActionTypes String[]            @default([]) @map("requested_action_types")
  requestedSourceTypes String[]            @default([]) @map("requested_source_types")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  completedAt          DateTime?           @map("completed_at")
  expiresAt            DateTime?           @map("expires_at")

  client       Client?      @relation(fields: [clientId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])

  @@index([clientId])
  @@index([orgId])
  @@index([status])
  @@map("client_intake_sessions")
}

// =============================================================
// NOTIFICATIONS (Phase 3C)
// =============================================================

enum NotificationChannel {
  DRY_RUN
}

enum NotificationStatus {
  PENDING
  SCHEDULED
  DELIVERED
  FAILED
  CANCELLED
}

model ScheduledNotification {
  id                  String              @id @default(cuid())
  clientId            String              @map("client_id")
  caseId              String?             @map("case_id")
  taskId              String?             @map("task_id")
  followUpReminderId  String?             @map("follow_up_reminder_id")
  channel             NotificationChannel @default(DRY_RUN)
  status              NotificationStatus  @default(PENDING)
  subjectSafe         String              @map("subject_safe")
  bodySafe            String              @map("body_safe")
  scheduledFor        DateTime            @map("scheduled_for")
  deliveredAt         DateTime?           @map("delivered_at")
  failedAt            DateTime?           @map("failed_at")
  cancelledAt         DateTime?           @map("cancelled_at")
  failureReason       String?             @map("failure_reason")
  createdByUserId     String?             @map("created_by_user_id")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  client    Client          @relation(fields: [clientId], references: [id])
  case      CleanupCase?    @relation(fields: [caseId], references: [id])
  task      CleanupTask?    @relation(fields: [taskId], references: [id])
  followUp  FollowUpReminder? @relation(fields: [followUpReminderId], references: [id])

  @@index([clientId, status])
  @@index([status, scheduledFor])
  @@index([followUpReminderId])
  @@map("scheduled_notifications")
}

// =============================================================
// REPORTS (Phase 4A)
// =============================================================

enum ReportType {
  CASE_SUMMARY
  EVIDENCE_SUMMARY
  FULL_CASE_EXPORT
  PROOF_PACKET
}

enum ExportFormat {
  JSON
  CSV
  PDF_STUB
}

enum ReportStatus {
  PENDING
  GENERATING
  READY
  FAILED
  EXPIRED
}

model CaseReport {
  id                  String       @id @default(cuid())
  clientId            String       @map("client_id")
  caseId              String?      @map("case_id")
  reportType          ReportType   @map("report_type")
  exportFormat        ExportFormat @map("export_format")
  status              ReportStatus @default(PENDING)
  redactedSummary     String       @map("redacted_summary")
  requestedByUserId   String?      @map("requested_by_user_id")
  generatedAt         DateTime?    @map("generated_at")
  failedAt            DateTime?    @map("failed_at")
  expiresAt           DateTime?    @map("expires_at")
  failureReason       String?      @map("failure_reason")
  vaultAccessLogId    String?      @map("vault_access_log_id")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  client Client      @relation(fields: [clientId], references: [id])
  case   CleanupCase? @relation(fields: [caseId], references: [id])

  @@index([clientId, status])
  @@index([caseId, status])
  @@index([status, expiresAt])
  @@map("case_reports")
}

// =============================================================
// AUTOMATION PLANS (Phase 4B)
// =============================================================

enum AutomationPlanStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXECUTING_DRY_RUN
  DRY_RUN_COMPLETE
  CANCELLED
}

model AutomationPlan {
  id                      String               @id @default(cuid())
  taskId                  String               @map("task_id")
  clientId                String               @map("client_id")
  status                  AutomationPlanStatus @default(PENDING_APPROVAL)
  intentJson              Json                 @map("intent_json")
  dryRunResultJson        Json?                @map("dry_run_result_json")
  approvedByUserId        String?              @map("approved_by_user_id")
  rejectedByUserId        String?              @map("rejected_by_user_id")
  rejectionReason         String?              @map("rejection_reason")
  cancelledByUserId       String?              @map("cancelled_by_user_id")
  approvedAt              DateTime?            @map("approved_at")
  rejectedAt              DateTime?            @map("rejected_at")
  dryRunStartedAt         DateTime?            @map("dry_run_started_at")
  dryRunCompletedAt       DateTime?            @map("dry_run_completed_at")
  cancelledAt             DateTime?            @map("cancelled_at")
  emergencyPauseBlockedAt DateTime?            @map("emergency_pause_blocked_at")
  createdByUserId         String?              @map("created_by_user_id")
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")

  task   CleanupTask @relation(fields: [taskId], references: [id])
  client Client      @relation(fields: [clientId], references: [id])

  @@index([taskId, status])
  @@index([clientId, createdAt])
  @@index([status])
  @@map("automation_plans")
}
