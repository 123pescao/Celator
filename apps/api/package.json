{
  "name": "@celator/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@celator/security": "workspace:*",
    "@celator/core": "workspace:*",
    "@celator/db": "workspace:*",
    "fastify": "^4.28.0",
    "@fastify/helmet": "^11.1.0",
    "pino": "^9.3.0",
    "dotenv": "^16.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "2.1.9",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
