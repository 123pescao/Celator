# =============================================================
# Celator — Environment Configuration
# =============================================================
# Copy this file to .env for local development.
# NEVER commit a real .env file.
# NEVER put real secrets here.
# =============================================================

# Database
DATABASE_URL="postgresql://celator:celator@localhost:5432/celator?schema=public"

# Local KMS (development only — NOT for production use)
# In production, replace with a real KMS provider (AWS KMS, GCP KMS, HashiCorp Vault).
LOCAL_KMS_MASTER_SECRET="replace-with-local-dev-secret-min-32-chars"
LOCAL_KMS_SIGNING_SECRET="replace-with-local-dev-signing-secret-min-32-chars"

# Runtime
NODE_ENV="development"
LOG_LEVEL="info"

# API
API_PORT="3000"
API_HOST="127.0.0.1"

# MFA freshness window (seconds) — how recently the operator must have completed MFA
MFA_FRESHNESS_WINDOW_SECONDS="14400"

# Approval rate limits
MAX_APPROVALS_PER_HOUR_STANDARD="30"
MAX_APPROVALS_PER_HOUR_HIGH_RISK="5"
MAX_APPROVALS_PER_SESSION_BEFORE_REAUTH="20"
MIN_REVIEW_TIME_SECONDS_STANDARD="60"
MIN_REVIEW_TIME_SECONDS_MEDIUM="120"
MIN_REVIEW_TIME_SECONDS_HIGH="300"
