{
  "name": "celator",
  "version": "0.0.1",
  "private": true,
  "description": "Celator — Operator-reviewed privacy operations platform. Phase 0: Security Foundation.",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @celator/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "prisma:generate": "pnpm --filter @celator/db prisma:generate",
    "prisma:validate": "pnpm --filter @celator/db prisma:validate",
    "prisma:migrate": "pnpm --filter @celator/db prisma:migrate"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  }
}
